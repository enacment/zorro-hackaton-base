<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="Zorro.Traspasos.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:Zorro.Traspasos.App.Pages"
    Shell.FlyoutBehavior="Disabled">

    <!-- Login route — no tab -->
    <ShellContent
        Route="login"
        ContentTemplate="{DataTemplate pages:LoginPage}"
        Shell.TabBarIsVisible="False" />

    <!-- Authenticated tab bar -->
    <TabBar>
        <ShellContent
            Title="Traspasos"
            Route="work"
            ContentTemplate="{DataTemplate pages:TraspasoPage}" />
        <ShellContent
            Title="Estado"
            Route="health"
            ContentTemplate="{DataTemplate pages:HealthPage}" />
    </TabBar>

</Shell>
