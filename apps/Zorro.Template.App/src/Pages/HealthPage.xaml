<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Zorro.Template.App.Pages.HealthPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Estado del sistema">

    <VerticalStackLayout
        Padding="24"
        Spacing="12"
        VerticalOptions="Start">

        <Label Text="Estado del sistema" FontSize="22" FontAttributes="Bold" />

        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
            <Label Grid.Row="0" Grid.Column="0" Text="App:" FontAttributes="Bold" />
            <Label x:Name="AppStatusLabel" Grid.Row="0" Grid.Column="1" Text="✅ OK" />

            <Label Grid.Row="1" Grid.Column="0" Text="API:" FontAttributes="Bold" />
            <Label x:Name="ApiStatusLabel" Grid.Row="1" Grid.Column="1" Text="—" />
        </Grid>

        <Label x:Name="EndpointLabel" Text="" FontSize="12" TextColor="Gray" />
        <Label x:Name="CheckTimeLabel" Text="" FontSize="12" TextColor="Gray" />

        <Button
            Text="Verificar estado"
            BackgroundColor="#3BB54A"
            TextColor="White"
            CornerRadius="8"
            HorizontalOptions="Start"
            Clicked="OnVerifyClicked" />

    </VerticalStackLayout>

</ContentPage>
