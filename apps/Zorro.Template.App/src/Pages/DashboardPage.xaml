<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Zorro.Template.App.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dashboard">

    <VerticalStackLayout
        Padding="24"
        Spacing="16"
        VerticalOptions="Start">

        <Label
            x:Name="WelcomeLabel"
            Text="Bienvenido"
            FontSize="24"
            FontAttributes="Bold" />

        <Label
            Text="Área de trabajo"
            FontSize="16"
            TextColor="Gray" />

        <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" Margin="0,8" />

        <Button
            Text="Cerrar sesión"
            BackgroundColor="#E53935"
            TextColor="White"
            CornerRadius="8"
            HorizontalOptions="Start"
            Clicked="OnLogoutClicked" />

    </VerticalStackLayout>

</ContentPage>
